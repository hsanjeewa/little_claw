# OpenRouter API Configuration
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-dummy-key-replace-me
LLM_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Engine Timeouts
SSH_TIMEOUT_SECONDS=30
LLM_TIMEOUT_SECONDS=15

# Per-host sudo (become) passwords — Ansible-style ansible_become_password.
# Key format: SUDO_PASS_<HOST_ALIAS with dashes as underscores>.
# Seeded into the encrypted vault at startup; leave unset to use passwordless
# sudo (sudo -n) on the target host.
# SUDO_PASS_WEB_PROD_01=your-sudo-password
# SUDO_PASS_DB_MASTER=your-sudo-password

